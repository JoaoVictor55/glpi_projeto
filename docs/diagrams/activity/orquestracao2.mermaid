flowchart TD
    start([Sistema iniciado])

    start --> wait[Administrador em espera]

    %% Evento externo
    event[Evento externo<br/>GLPI / Usuário]
    event --> enqueue[Adicionar tarefa à fila]

    %% Polling
    wait --> timer{{Timer expirou?}}
    timer -- Não --> wait
    timer -- Sim --> checkQueue

    enqueue --> checkQueue

    checkQueue{Fila possui tarefas?}
    checkQueue -- Não --> wait
    checkQueue -- Sim --> selectTask[Selecionar tarefa]

    selectTask --> dispatch[Despachar tarefa]
    dispatch --> execute[Executar ação]
    execute --> update[Atualizar tarefa]
    update --> checkQueue
